# 复制为 .env 后按需修改（切勿提交 .env 到 Git）
# cp .env.example .env

# 数据库
DATABASE_URL=postgresql://ops_user:ops_pass@postgres:5432/ops_automation_plateform
POSTGRES_USER=ops_user
POSTGRES_PASSWORD=ops_pass
POSTGRES_DB=ops_automation_plateform

# Redis
REDIS_URL=redis://redis:6379/0

# JWT 签名密钥（HS256，建议至少 32 个字符）
SECRET_KEY=ops-automation-plateform-dev-jwt-secret-min-32-chars

# SSH 密码 Fernet 加密密钥（必须为 44 位 url-safe Base64 字符串）
# 重新生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=XVur7auYkJ4nPdWBXjRH2RPtnTigwL_oN7VR7CKalzY=

# Prometheus（Docker 内网地址，一般无需修改）
PROMETHEUS_URL=http://prometheus:9090

# 时区
TZ=Asia/Shanghai
PGTZ=Asia/Shanghai

# SMTP 邮件（告警/定时任务通知，不需要邮件功能可留空）
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
